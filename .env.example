# CRES-CA — environment variables template
# Copy to .env.local and fill in values. Never commit .env.local.

# ───── Supabase ─────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ───── App ─────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ───── Telegram Bot ─────
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=

# ───── Cron ─────
CRON_SECRET=

# ───── AI / Voice ─────
OPENAI_API_KEY=
GOOGLE_AI_STUDIO_KEY=
OPENROUTER_API_KEY=

# ───── Payments · LiqPay (current) ─────
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# ───── Payments · Hutko (Phase 3 stub — not live yet) ─────
HUTKO_API_KEY=
HUTKO_WEBHOOK_SECRET=
HUTKO_STORE_ID=

# ───── OAuth ─────
# Configured in Supabase Dashboard (Auth → Providers)
